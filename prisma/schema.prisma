generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            BigInt                   @id @default(autoincrement())
  username                      String                   @unique @db.VarChar(100)
  email                         String                   @unique @db.VarChar(100)
  passwordHash                  String                   @map("password_hash") @db.VarChar(255)
  active                        Boolean                  @default(true)
  emailVerified                 Boolean                  @default(false) @map("email_verified")
  createdAt                     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscriptionProvider          SubscriptionProvider?    @map("subscription_provider")
  stripeCustomerId              String?                  @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId          String?                  @map("stripe_subscription_id") @db.VarChar(255)
  appleOriginalTransactionId    String?                  @map("apple_original_transaction_id") @db.VarChar(255)
  appleProductId                String?                  @map("apple_product_id") @db.VarChar(255)
  subscriptionEndsAt            DateTime?                @map("subscription_ends_at") @db.Timestamptz(6)
  subscriptionStartsAt          DateTime?                @map("subscription_starts_at") @db.Timestamptz(6)
  subscriptionStatus            SubscriptionStatus       @default(active) @map("subscription_status")
  subscriptionCancelAtPeriodEnd Boolean                  @default(false) @map("subscription_cancel_at_period_end")
  subscriptionTier              SubscriptionTier         @default(free) @map("subscription_tier")
  dataExports                   DataExport[]
  courseRequests                CourseRequest[]
  feedbackSubmissions           UserFeedback[]
  friendRequestsReceived        FriendRequest[]          @relation("RecipientRelation")
  friendRequestsSent            FriendRequest[]          @relation("RequesterRelation")
  friendNotificationsReceived   FriendNotification[]     @relation("FriendNotificationRecipient")
  friendNotificationsActed      FriendNotification[]     @relation("FriendNotificationActor")
  friendsReceived               Friend[]                 @relation("FriendOfUser")
  friendsInitiated              Friend[]                 @relation("UserFriends")
  lifetimeGrants                LifetimeGrant[]
  overallInsight                OverallInsight?
  RoundInsights                 RoundInsight[]
  roundStrokesGaineds           RoundStrokesGained[]
  rounds                        Round[]
  liveRoundSessions             LiveRoundSession[]
  subscriptionEvents            SubscriptionEvent[]
  userAchievementEvents         UserAchievementEvent[]
  userAchievementProgress       UserAchievementProgress?
  userAchievements              UserAchievement[]
  leaderboardStats              UserLeaderboardStats?
  profile                       UserProfile?
  oauthAccounts                 OAuthAccount[]
  reportsFiled                  UserReport[]             @relation("ReportsFiled")
  reportsReceived               UserReport[]             @relation("ReportsReceived")
  blocksInitiated               UserBlock[]              @relation("BlocksInitiated")
  blocksReceived                UserBlock[]              @relation("BlocksReceived")

  @@index([subscriptionTier, subscriptionStatus], map: "idx_users_subscription")
  @@index([stripeCustomerId], map: "idx_users_stripe_customer")
  @@map("users")
}

model UserReport {
  id             BigInt           @id @default(autoincrement())
  reporterId     BigInt           @map("reporter_id")
  reportedUserId BigInt           @map("reported_user_id")
  reason         UserReportReason
  details        String?
  status         UserReportStatus @default(open)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  reporter       User             @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User             @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@unique([reporterId, reportedUserId, status], map: "uq_user_reports_reporter_reported_status")
  @@index([reporterId], map: "idx_user_reports_reporter")
  @@index([reportedUserId], map: "idx_user_reports_reported")
  @@index([status], map: "idx_user_reports_status")
  @@index([createdAt], map: "idx_user_reports_created_at")
  @@map("user_reports")
}

model UserBlock {
  id            BigInt   @id @default(autoincrement())
  blockerId     BigInt   @map("blocker_id")
  blockedUserId BigInt   @map("blocked_user_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  blocker       User     @relation("BlocksInitiated", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId], map: "uq_user_blocks_blocker_blocked")
  @@index([blockerId], map: "idx_user_blocks_blocker")
  @@index([blockedUserId], map: "idx_user_blocks_blocked")
  @@index([createdAt], map: "idx_user_blocks_created_at")
  @@map("user_blocks")
}

model OAuthAccount {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @map("user_id")
  provider          String   @db.VarChar(32)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  email             String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "oauth_accounts_provider_provider_account_key")
  @@index([userId], map: "idx_oauth_accounts_user_id")
  @@index([email], map: "idx_oauth_accounts_email")
  @@map("oauth_accounts")
}

model UserProfile {
  id                                 BigInt              @id @default(autoincrement())
  userId                             BigInt              @unique @map("user_id")
  firstName                          String?             @map("first_name") @db.VarChar(100)
  lastName                           String?             @map("last_name") @db.VarChar(100)
  avatarUrl                          String              @default("/avatars/default.png") @map("avatar_url") @db.VarChar(255)
  bio                                String?
  gender                             Gender              @default(unspecified)
  defaultTee                         DefaultTee          @default(white) @map("default_tee")
  favoriteCourseId                   BigInt?             @map("favorite_course_id")
  dashboardVisibility                DashboardVisibility @default(friends) @map("dashboard_visibility")
  createdAt                          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  theme                              String              @default("dark") @db.VarChar(50)
  timezone                           String?             @db.VarChar(100)
  showStrokesGained                  Boolean             @default(true) @map("show_strokes_gained")
  liveRoundTrackFir                  Boolean             @default(true) @map("live_round_track_fir")
  liveRoundTrackGir                  Boolean             @default(true) @map("live_round_track_gir")
  liveRoundTrackChips                Boolean             @default(true) @map("live_round_track_chips")
  liveRoundTrackGreensideBunkerShots Boolean             @default(true) @map("live_round_track_greenside_bunker_shots")
  liveRoundTrackPutts                Boolean             @default(true) @map("live_round_track_putts")
  liveRoundTrackPenalties            Boolean             @default(true) @map("live_round_track_penalties")
  favoriteCourse                     Course?             @relation(fields: [favoriteCourseId], references: [id])
  user                               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dashboardVisibility], map: "idx_dashboard_visibility")
  @@map("user_profiles")
}

model UserLeaderboardStats {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @unique @map("user_id")
  handicap     Decimal? @db.Decimal(4, 1)
  averageScore Decimal? @map("average_score") @db.Decimal(5, 1)
  bestScore    Int?     @map("best_score") @db.SmallInt
  totalRounds  Int      @default(0) @map("total_rounds")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  averageToPar Decimal? @map("average_to_par") @db.Decimal(5, 1)
  bestToPar    Decimal? @map("best_to_par") @db.Decimal(5, 1)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([handicap], map: "idx_handicap")
  @@index([averageScore], map: "idx_average_score")
  @@index([averageToPar], map: "idx_average_to_par")
  @@index([totalRounds], map: "idx_total_rounds")
  @@map("user_leaderboard_stats")
}

model PasswordResetToken {
  id        BigInt    @id @default(autoincrement())
  email     String    @db.VarChar(100)
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email], map: "idx_password_reset_email")
  @@index([token], map: "idx_password_reset_token")
  @@index([expiresAt], map: "idx_password_reset_expires")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        BigInt    @id @default(autoincrement())
  email     String    @db.VarChar(100)
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email], map: "idx_email_verification_email")
  @@index([token], map: "idx_email_verification_token")
  @@index([expiresAt], map: "idx_email_verification_expires")
  @@map("email_verification_tokens")
}

model Course {
  id                 BigInt             @id @default(autoincrement())
  clubName           String             @map("club_name") @db.VarChar(255)
  courseName         String             @map("course_name") @db.VarChar(255)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  verified           Boolean            @default(false)
  location           Location?
  mappedCourse       MappedCourse?
  rounds             Round[]
  liveRoundSessions  LiveRoundSession[]
  tees               Tee[]
  favoriteByProfiles UserProfile[]

  @@index([verified], map: "idx_course_verified")
  @@map("courses")
}

model MappedCourse {
  id            BigInt           @id @default(autoincrement())
  courseId      BigInt           @unique @map("course_id")
  boundsNorth   Decimal?         @map("bounds_north") @db.Decimal(10, 7)
  boundsSouth   Decimal?         @map("bounds_south") @db.Decimal(10, 7)
  boundsEast    Decimal?         @map("bounds_east") @db.Decimal(10, 7)
  boundsWest    Decimal?         @map("bounds_west") @db.Decimal(10, 7)
  minZoom       Decimal?         @map("min_zoom") @db.Decimal(5, 2)
  maxZoom       Decimal?         @map("max_zoom") @db.Decimal(5, 2)
  mappingStatus GpsMappingStatus @default(DRAFT) @map("mapping_status")
  source        GpsMappingSource @default(UNKNOWN)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  holes         MappedHole[]

  @@index([mappingStatus], map: "idx_mapped_courses_status")
  @@index([source], map: "idx_mapped_courses_source")
  @@map("mapped_courses")
}

model MappedHole {
  id             BigInt           @id @default(autoincrement())
  mappedCourseId BigInt           @map("mapped_course_id")
  holeNumber     Int              @map("hole_number")
  teeLat         Decimal?         @map("tee_lat") @db.Decimal(10, 7)
  teeLng         Decimal?         @map("tee_lng") @db.Decimal(10, 7)
  target1Lat     Decimal?         @map("target1_lat") @db.Decimal(10, 7)
  target1Lng     Decimal?         @map("target1_lng") @db.Decimal(10, 7)
  target1Label   String?          @map("target1_label") @db.VarChar(100)
  target2Lat     Decimal?         @map("target2_lat") @db.Decimal(10, 7)
  target2Lng     Decimal?         @map("target2_lng") @db.Decimal(10, 7)
  target2Label   String?          @map("target2_label") @db.VarChar(100)
  greenFrontLat  Decimal?         @map("green_front_lat") @db.Decimal(10, 7)
  greenFrontLng  Decimal?         @map("green_front_lng") @db.Decimal(10, 7)
  greenCenterLat Decimal?         @map("green_center_lat") @db.Decimal(10, 7)
  greenCenterLng Decimal?         @map("green_center_lng") @db.Decimal(10, 7)
  greenBackLat   Decimal?         @map("green_back_lat") @db.Decimal(10, 7)
  greenBackLng   Decimal?         @map("green_back_lng") @db.Decimal(10, 7)
  mappingStatus  GpsMappingStatus @default(DRAFT) @map("mapping_status")
  source         GpsMappingSource @default(UNKNOWN)
  verifiedAt     DateTime?        @map("verified_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  mappedCourse   MappedCourse     @relation(fields: [mappedCourseId], references: [id], onDelete: Cascade)

  @@unique([mappedCourseId, holeNumber], map: "uq_mapped_holes_course_hole")
  @@index([mappedCourseId], map: "idx_mapped_holes_mapped_course_id")
  @@index([mappedCourseId, mappingStatus], map: "idx_mapped_holes_course_status")
  @@index([mappingStatus], map: "idx_mapped_holes_status")
  @@index([source], map: "idx_mapped_holes_source")
  @@map("mapped_holes")
}

model Location {
  id        BigInt   @id @default(autoincrement())
  courseId  BigInt   @unique @map("course_id")
  address   String?  @db.VarChar(255)
  city      String?  @db.VarChar(100)
  state     String?  @db.VarChar(50)
  country   String?  @db.VarChar(50)
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], map: "idx_location_course_id")
  @@map("locations")
}

model Tee {
  id                BigInt             @id @default(autoincrement())
  courseId          BigInt             @map("course_id")
  gender            TeeGender
  teeName           String             @map("tee_name") @db.VarChar(100)
  courseRating      Decimal?           @map("course_rating") @db.Decimal(5, 2)
  slopeRating       Int?               @map("slope_rating")
  bogeyRating       Decimal?           @map("bogey_rating") @db.Decimal(5, 2)
  totalYards        Int?               @map("total_yards")
  totalMeters       Int?               @map("total_meters")
  numberOfHoles     Int?               @map("number_of_holes")
  parTotal          Int?               @map("par_total")
  frontCourseRating Decimal?           @map("front_course_rating") @db.Decimal(5, 2)
  frontSlopeRating  Int?               @map("front_slope_rating")
  frontBogeyRating  Decimal?           @map("front_bogey_rating") @db.Decimal(5, 2)
  backCourseRating  Decimal?           @map("back_course_rating") @db.Decimal(5, 2)
  backSlopeRating   Int?               @map("back_slope_rating")
  backBogeyRating   Decimal?           @map("back_bogey_rating") @db.Decimal(5, 2)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  nonPar3Holes      Int                @map("non_par3_holes")
  holes             Hole[]
  rounds            Round[]
  liveRoundSessions LiveRoundSession[]
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], map: "idx_tee_course_id")
  @@map("tees")
}

model Hole {
  id                  BigInt               @id @default(autoincrement())
  teeId               BigInt               @map("tee_id")
  holeNumber          Int                  @map("hole_number")
  par                 Int
  yardage             Int
  handicap            Int?
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  tee                 Tee                  @relation(fields: [teeId], references: [id], onDelete: Cascade)
  roundHoles          RoundHole[]
  liveRoundHoleDrafts LiveRoundHoleDraft[]

  @@index([teeId], map: "idx_hole_tee_id")
  @@map("holes")
}

model Round {
  id                        BigInt                 @id @default(autoincrement())
  userId                    BigInt                 @map("user_id")
  courseId                  BigInt                 @map("course_id")
  teeId                     BigInt                 @map("tee_id")
  holeByHole                Boolean                @default(false) @map("hole_by_hole")
  date                      DateTime               @db.Timestamptz(6)
  score                     Int
  netScore                  Int?                   @map("net_score")
  firHit                    Int?                   @map("fir_hit")
  girHit                    Int?                   @map("gir_hit")
  putts                     Int?
  penalties                 Int?
  chips                     Int?
  greensideBunkerShots      Int?                   @map("greenside_bunker_shots")
  shortGameShots            Int?                   @map("short_game_shots")
  notes                     String?
  createdAt                 DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  toPar                     Int?                   @map("to_par") @db.SmallInt
  netToPar                  Int?                   @map("net_to_par") @db.SmallInt
  handicapAtRound           Decimal?               @map("handicap_at_round") @db.Decimal(4, 1)
  teeSegment                String                 @default("full") @map("tee_segment")
  holesPlayed               Int                    @default(18) @map("holes_played")
  roundContext              RoundContext           @default(real) @map("round_context")
  roundHoles                RoundHole[]
  RoundInsight              RoundInsight?
  roundStrokesGained        RoundStrokesGained?
  finalizedLiveRoundSession LiveRoundSession?      @relation("FinalizedLiveRound")
  course                    Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tee                       Tee                    @relation(fields: [teeId], references: [id])
  user                      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAchievementEvents     UserAchievementEvent[]

  @@index([userId], map: "idx_user_id")
  @@index([userId, roundContext], map: "idx_round_user_context")
  @@index([courseId], map: "idx_round_course_id")
  @@index([teeId], map: "idx_round_tee_id")
  @@map("rounds")
}

model RoundHole {
  id                   BigInt              @id @default(autoincrement())
  roundId              BigInt              @map("round_id")
  holeId               BigInt              @map("hole_id")
  pass                 Int                 @default(1) @map("pass") @db.SmallInt
  score                Int
  firHit               Int?                @map("fir_hit")
  firDirection         RoundMissDirection? @map("fir_direction")
  girHit               Int?                @map("gir_hit")
  girDirection         RoundMissDirection? @map("gir_direction")
  putts                Int?
  penalties            Int?
  chips                Int?
  greensideBunkerShots Int?                @map("greenside_bunker_shots")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  hole                 Hole                @relation(fields: [holeId], references: [id], onDelete: Cascade)
  round                Round               @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, holeId, pass], name: "unique_round_hole_pass")
  @@index([roundId], map: "idx_round_id")
  @@index([holeId], map: "idx_hole_id")
  @@map("round_holes")
}

model LiveRoundSession {
  id                                 BigInt                 @id @default(autoincrement())
  userId                             BigInt                 @map("user_id")
  courseId                           BigInt                 @map("course_id")
  teeId                              BigInt                 @map("tee_id")
  finalRoundId                       BigInt?                @unique @map("final_round_id")
  status                             LiveRoundSessionStatus @default(ACTIVE)
  date                               DateTime               @db.Timestamptz(6)
  teeSegment                         String                 @default("full") @map("tee_segment")
  roundContext                       RoundContext           @default(real) @map("round_context")
  notes                              String?
  startHoleNumber                    Int                    @default(1) @map("start_hole_number")
  activeHoleNumber                   Int                    @default(1) @map("active_hole_number")
  activeHolePass                     Int                    @default(1) @map("active_hole_pass") @db.SmallInt
  activeStep                         LiveRoundActiveStep    @default(SCORE) @map("active_step")
  liveRoundTrackFir                  Boolean                @default(true) @map("live_round_track_fir")
  liveRoundTrackGir                  Boolean                @default(true) @map("live_round_track_gir")
  liveRoundTrackChips                Boolean                @default(true) @map("live_round_track_chips")
  liveRoundTrackGreensideBunkerShots Boolean                @default(true) @map("live_round_track_greenside_bunker_shots")
  liveRoundTrackPutts                Boolean                @default(true) @map("live_round_track_putts")
  liveRoundTrackPenalties            Boolean                @default(true) @map("live_round_track_penalties")
  startedAt                          DateTime               @default(now()) @map("started_at") @db.Timestamptz(6)
  lastSavedAt                        DateTime               @default(now()) @map("last_saved_at") @db.Timestamptz(6)
  completedAt                        DateTime?              @map("completed_at") @db.Timestamptz(6)
  discardedAt                        DateTime?              @map("discarded_at") @db.Timestamptz(6)
  createdAt                          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  course                             Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  finalRound                         Round?                 @relation("FinalizedLiveRound", fields: [finalRoundId], references: [id], onDelete: SetNull)
  holeDrafts                         LiveRoundHoleDraft[]
  tee                                Tee                    @relation(fields: [teeId], references: [id])
  user                               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastSavedAt], map: "idx_live_round_sessions_user_status_saved")
  @@index([userId, status, updatedAt], map: "idx_live_round_sessions_user_status_updated")
  @@index([courseId], map: "idx_live_round_sessions_course_id")
  @@index([teeId], map: "idx_live_round_sessions_tee_id")
  @@index([status], map: "idx_live_round_sessions_status")
  @@map("live_round_sessions")
}

model LiveRoundHoleDraft {
  id                   BigInt              @id @default(autoincrement())
  sessionId            BigInt              @map("session_id")
  holeId               BigInt              @map("hole_id")
  holeNumber           Int                 @map("hole_number")
  displayHoleNumber    Int                 @map("display_hole_number")
  pass                 Int                 @default(1) @map("pass") @db.SmallInt
  score                Int?
  firHit               Int?                @map("fir_hit")
  firDirection         RoundMissDirection? @map("fir_direction")
  girHit               Int?                @map("gir_hit")
  girDirection         RoundMissDirection? @map("gir_direction")
  putts                Int?
  penalties            Int?
  chips                Int?
  greensideBunkerShots Int?                @map("greenside_bunker_shots")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  hole                 Hole                @relation(fields: [holeId], references: [id], onDelete: Cascade)
  session              LiveRoundSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, holeId, pass], map: "uq_live_round_hole_drafts_session_hole_pass")
  @@index([sessionId], map: "idx_live_round_hole_drafts_session_id")
  @@index([sessionId, displayHoleNumber], map: "idx_live_round_hole_drafts_session_display")
  @@index([holeId], map: "idx_live_round_hole_drafts_hole_id")
  @@map("live_round_hole_drafts")
}

model FriendRequest {
  id          BigInt   @id @default(autoincrement())
  requesterId BigInt   @map("requester_id")
  recipientId BigInt   @map("recipient_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
